# Frontend (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Google Cloud Console → APIs & Services → Credentials → API key
# Enable: Places API (New) — restrict to your domain in production
VITE_GOOGLE_PLACES_API_KEY=

# Supabase Edge Function secrets (set via: supabase secrets set KEY=value)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
BUSINESS_NAME=

# Email — Resend (resend.com)
RESEND_API_KEY=
OWNER_EMAIL=

# SMS — Twilio (twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
OWNER_PHONE=

# Google Calendar (optional)
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=

# RentCast — property data enrichment (rentcast.io)
# Used by the lookup-property edge function to fetch bedrooms, sq ft, etc.
# from a customer's address at intake time.
RENTCAST_API_KEY=
